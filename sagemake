#!/usr/bin/env python3
"""
sagemake — Build system for Bonsai Agent Harness

A SageLang-based agent harness that connects to Ollama and provides
a TUI with tool-calling capabilities using the Bonsai-27B model.

Usage:
    ./sagemake [command] [flags]

Commands:
    build      Verify syntax and run lint checks
    compile    Try to compile a native binary (--aot --jit)
    run        Run the harness with JIT profiling
    test       Run self-tests
    bench      Run the model benchmark suite
    install    Install to /usr/local/bin
    clean      Remove build artifacts
    all        Run build then test
"""

import hashlib
import os
import platform
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"

ROOT = Path(__file__).resolve().parent
LIB_DIR = ROOT / "lib"
BINARY_NAME = "bonsai-harness"
MAIN_SAGE = "src/main.sage"
SAGE = shutil.which("sage") or "/usr/local/bin/sage"


def banner(title):
    width = 60
    line = f"{CYAN}{'═' * width}{RESET}"
    print(f"\n{line}")
    print(f"{CYAN}  {BOLD}{title}{RESET}")
    print(f"{line}\n")


def section(title):
    print(f"  {CYAN}→{RESET} {title}")


def step(msg):
    print(f"    {msg} ... ", end="", flush=True)


def ok():
    print(f"{GREEN}✓ done{RESET}")


def fail():
    print(f"{RED}✗ failed{RESET}")
    sys.exit(1)


def step_ok(detail):
    print(f"{GREEN}✓ {detail}{RESET}")


def step_fail(detail):
    print(f"{RED}✗ {detail}{RESET}")
    sys.exit(1)


def step_warn(detail):
    print(f"{YELLOW}! {detail}{RESET}")


def run_cmd(cmd, **kwargs):
    if "env" in kwargs:
        kwargs["env"] = {**os.environ, **kwargs["env"]}
    else:
        kwargs["env"] = os.environ.copy()
    try:
        return subprocess.run(cmd, check=True, **kwargs)
    except subprocess.CalledProcessError as e:
        step_fail(f"command failed with exit {e.returncode}: {' '.join(cmd)}")
    except FileNotFoundError:
        step_fail(f"command not found: {cmd[0]}")


def check_dependencies():
    section("Dependencies")
    required = ["sage", "ollama"]
    for dep in required:
        step(f"checking {dep}")
        if shutil.which(dep) is None:
            print(f"{RED}✗ not found{RESET}")
            step_fail(f"missing: {dep}")
        else:
            ok()

    step("checking ollama is running")
    try:
        r = subprocess.run(
            ["ollama", "list"],
            capture_output=True, text=True, timeout=10,
        )
        if r.returncode == 0:
            ok()
        else:
            step_warn("ollama not running (start with: ollama serve)")
    except Exception:
        step_warn("could not reach ollama daemon")


def cmd_build(args):
    banner("build — Bonsai Agent Harness")
    check_dependencies()

    section("Syntax check")
    sage_files = sorted(ROOT.rglob("*.sage"))
    errors = 0
    for f in sage_files:
        rel = f.relative_to(ROOT)
        step(f"checking {rel}")
        r = subprocess.run(
            [SAGE, "lint", str(f)],
            capture_output=True, text=True, timeout=30,
        )
        stderr_lower = r.stderr.lower()
        if "syntax error" in stderr_lower or "error" in stderr_lower:
            print(f"{RED}✗ failed{RESET}")
            print(r.stderr)
            errors += 1
        else:
            ok()

    if errors:
        step_fail(f"{errors} file(s) failed syntax check")

    step_ok("all files pass syntax check")


def cmd_compile(args):
    banner("compile — Bonsai Agent Harness (JIT binary)")
    check_dependencies()

    section("Compilation")

    out_path = ROOT / BINARY_NAME

    step("building JIT-packaged binary")
    jit_bin = out_path.with_name(out_path.name + ".jit")
    result = subprocess.run(
        [SAGE, "--jit", MAIN_SAGE, "-o", str(jit_bin)],
        capture_output=True, text=True, timeout=120,
        cwd=ROOT,
    )

    if result.returncode == 0 and jit_bin.exists():
        ok()
        step_ok(f"JIT binary at {jit_bin}")
    else:
        step_warn("JIT packaging failed, falling back to interpreter")
        for line in result.stderr.split("\n")[:5]:
            if line.strip():
                print(f"      {YELLOW}{line.strip()}{RESET}")
        jit_bin = None

    step("creating run script")
    if jit_bin:
        run_script = ROOT / BINARY_NAME
        run_script.write_text(
            f"#!/bin/sh\n"
            f'export SAGE_PATH="{ROOT}:{LIB_DIR}:${{SAGE_PATH:-}}"\n'
            f'exec "{jit_bin}" "$@"\n'
        )
    else:
        run_script = ROOT / BINARY_NAME
        run_script.write_text(
            f"#!/bin/sh\n"
            f'exec {SAGE} --runtime jit -I "{ROOT}" -I "{LIB_DIR}" "{ROOT / MAIN_SAGE}" "$@"\n'
        )
    run_script.chmod(0o755)
    step_ok(f"script at {run_script}")


def cmd_run(args):
    banner("run — Bonsai Agent Harness")
    check_dependencies()

    section("Launching")
    cmd = [SAGE, "--runtime", "jit", MAIN_SAGE]
    if args:
        cmd.extend(args)

    sage_path = os.environ.get("SAGE_PATH", "")
    sage_path = f"{ROOT}:{LIB_DIR}:{sage_path}" if sage_path else f"{ROOT}:{LIB_DIR}"
    env = {**os.environ, "SAGE_PATH": sage_path}

    step(f"executing: {' '.join(cmd)}")
    print()
    try:
        subprocess.run(cmd, cwd=ROOT, env=env)
    except KeyboardInterrupt:
        print()
        step_warn("interrupted")


def cmd_test(args):
    banner("test — Bonsai Agent Harness")
    section("Running self-tests")

    test_suites = [
        ROOT / "tests" / "test_tools.sage",
        ROOT / "tests" / "test_skills.sage",
        ROOT / "tests" / "test_benchmark.sage",
        ROOT / "tests" / "test_model_router.sage",
        ROOT / "tests" / "test_tool_compiler.sage",
        ROOT / "tests" / "test_tool_validator.sage",
        ROOT / "tests" / "test_agent_loop.sage",
        ROOT / "tests" / "test_tui.sage",
    ]
    errors = 0
    for script in test_suites:
        if not script.exists():
            step_warn(f"skipped: {script.name} (not found)")
            continue
        step(f"executing {script.name}")
        r = subprocess.run(
            [SAGE, str(script)],
            capture_output=True, text=True, timeout=120,
            cwd=ROOT,
        )
        if r.returncode != 0:
            print(r.stdout)
            print(r.stderr)
            errors += 1
        else:
            print(r.stdout)
    if errors:
        step_fail(f"{errors} test suite(s) failed")
    step_ok("all test suites passed")


BENCH_CATEGORIES = ["reasoning", "knowledge", "coding", "tool_use", "instruction", "reading_comprehension", "commonsense_reasoning", "tool_compilation"]


def _bench_bar(pct):
    width = 20
    filled = pct * width // 100
    return "█" * filled + "░" * (width - filled)


def cmd_bench(args):
    banner("bench — Bonsai Agent Harness")
    check_dependencies()
    section("Running model benchmark (per-category process isolation)")
    print()
    script = ROOT / "bench" / "run_bench.sage"
    if not script.exists():
        step_fail("bench/run_bench.sage not found")

    categories = args if args else BENCH_CATEGORIES
    grand_correct = 0
    grand_total = 0

    for cat in categories:
        env = {"BENCH_CATEGORY": cat}
        try:
            r = subprocess.run(
                [SAGE, str(script)],
                cwd=ROOT,
                env={**os.environ, **env},
                capture_output=True, text=True, timeout=1800,
            )
        except KeyboardInterrupt:
            print()
            step_warn("interrupted")
            return
        except subprocess.TimeoutExpired:
            step_warn(f"{cat}: timed out")
            continue

        # Echo the human-readable lines, parse the machine-readable SCORE line.
        for line in r.stdout.splitlines():
            if line.startswith("SCORE "):
                parts = line.split()
                if len(parts) == 4:
                    grand_correct += int(parts[2])
                    grand_total += int(parts[3])
            else:
                print(line)
        print()

    if grand_total == 0:
        step_fail("no benchmark results collected")

    overall = grand_correct * 100 // grand_total
    color = GREEN if overall >= 80 else (YELLOW if overall >= 50 else RED)
    print(f"{CYAN}{'═' * 50}{RESET}")
    print(f"{BOLD}OVERALL: {RESET}{color}{overall}%{RESET} ({grand_correct}/{grand_total} tasks)")
    print(f"{CYAN}{'═' * 50}{RESET}\n")


def cmd_install(args):
    banner("install — Bonsai Agent Harness")
    install_dir = Path("/usr/local/bin")
    source = ROOT / BINARY_NAME
    target = install_dir / BINARY_NAME
    step(f"installing to {target}")
    if not source.exists():
        step_fail(f"{BINARY_NAME} not found — run 'compile' first")
    try:
        install_dir.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)
        target.chmod(0o755)
    except PermissionError:
        step_fail("permission denied (try sudo)")
    except Exception as e:
        step_fail(f"install failed: {e}")
    step_ok(f"installed {BINARY_NAME}")


def cmd_clean(args):
    banner("clean — Bonsai Agent Harness")
    section("Removing artifacts")
    artifacts = [
        ROOT / BINARY_NAME,
        ROOT / "src" / "bonsai.c",
        ROOT / "src" / "bonsai.ll",
        ROOT / "build",
    ]
    for p in artifacts:
        if p.exists():
            step(f"removing {p.name}")
            try:
                if p.is_dir():
                    shutil.rmtree(p)
                else:
                    p.unlink()
                ok()
            except Exception as e:
                step_fail(f"failed: {e}")
    step_ok("clean complete")


def cmd_all(args):
    cmd_build(args)
    cmd_test(args)


def main():
    commands = {
        "build": cmd_build,
        "compile": cmd_compile,
        "run": cmd_run,
        "test": cmd_test,
        "bench": cmd_bench,
        "install": cmd_install,
        "clean": cmd_clean,
        "all": cmd_all,
    }

    if len(sys.argv) < 2 or sys.argv[1] not in commands:
        banner("Bonsai Agent Harness — sagemake")
        print(f"  Usage:  ./sagemake {'|'.join(commands.keys())}")
        print()
        print(f"  {CYAN}build{RESET}    Check syntax and dependencies")
        print(f"  {CYAN}compile{RESET}  Try native binary (falls back to run script)")
        print(f"  {CYAN}run{RESET}      Launch the harness with JIT")
        print(f"  {CYAN}test{RESET}     Run tests")
        print(f"  {CYAN}bench{RESET}    Run model benchmark suite")
        print(f"  {CYAN}install{RESET}  Install binary")
        print(f"  {CYAN}clean{RESET}    Remove artifacts")
        print(f"  {CYAN}all{RESET}      build + test")
        print()
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]
    commands[cmd](args)


if __name__ == "__main__":
    main()
